[Unit]
Description=Disk Usage Daemon
After=network.target multi-user.target NetworkManager.service

[Service]
Type=simple
ExecStart=/usr/local/bin/dsk-daemon.sh run RUN
ExitType=main
Restart=on-failure
RestartSec=5s



[Install]
WantedBy=multi-user.target




