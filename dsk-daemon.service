# 
#
# For Modification visit  man
#  systemd.unit 
#  systemd.service 
#
 
[Unit] 
Description=Disk Usage Daemon
After=network.target multi-user.target NetworkManager.service 

[Service] 
Type=simple
ExecStart=/home/blue/bin/dsk-daemon.sh run
ExecReload=/home/blue/bin/dsk-daemon.sh  Restart
ExitType=main  
Restart=on-failure
RestartSec=25ms 



[Install] 
WantedBy=multi-user.target






