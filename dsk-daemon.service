[Unit] 
Description=Disk Usage Daemon
After=network.target multi-user.target NetworkManager.service 

[Service] 
Type=exec
ExecStart=/home/blue/dskd/dsk-daemon.sh 
ExitType=main  
Restart=on-failure
RestartSec=5ms 



[Install] 
WantedBy=multi-user.target






